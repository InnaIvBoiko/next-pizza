# Copy to .env.local for local dev. On Vercel, set these in
# Project Settings → Environment Variables (no .env file is uploaded).

# --- Database (Postgres) ---
# Runtime uses POSTGRES_URL via @prisma/adapter-pg.
# On Vercel/serverless use the POOLED connection string (e.g. Neon pooler),
# not the direct one, to avoid exhausting connections.
POSTGRES_URL=postgresql://user:password@host/db?sslmode=require
# Used only by Prisma CLI (migrate/studio/seed); a direct (non-pooled) URL.
PRISMA_DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# --- NextAuth ---
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
# Set to the canonical production URL on Vercel (https://your-app.vercel.app).
NEXTAUTH_URL=http://localhost:3000

# --- Public URLs (exposed to the browser) ---
# Must point to the deployed origin in production. NEXT_PUBLIC_API_URL has no
# code fallback — if unset, client API calls have no baseURL and break.
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# --- Google OAuth ---
# Add the prod redirect URI in Google console:
# https://your-app.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
# From the Stripe webhook endpoint configured to hit /api/checkout/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Resend (email) ---
# In production the From address must use a domain verified in Resend.
RESEND_API_KEY=re_...
RESEND_FROM=Next Pizza <onboarding@resend.dev>
