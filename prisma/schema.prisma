generator client {
    provider = "prisma-client"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
}

model User {
    id Int @id @default(autoincrement())

    fullName String
    email    String    @unique
    password String?
    role     UserRole  @default(USER)
    verified DateTime?

    provider   String?
    providerId String?

    cart             Cart?
    orders           Order[]
    verificationCode VerificationCode?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Category {
    id       Int       @id @default(autoincrement())
    name     String    @unique
    // Italian translation; `name` holds the default/source (English) value.
    nameIt   String?
    products Product[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Product {
    id Int @id @default(autoincrement())

    name     String
    imageUrl String

    ingredients Ingredient[]
    items       ProductItem[]

    category   Category @relation(fields: [categoryId], references: [id])
    categoryId Int

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model ProductItem {
    id Int @id @default(autoincrement())

    price     Float
    size      Int?
    pizzaType Int?

    cartItems CartItem[]

    product   Product @relation(fields: [productId], references: [id])
    productId Int
}

model Ingredient {
    id Int @id @default(autoincrement())

    name     String
    // Italian translation; `name` holds the default/source (English) value.
    nameIt   String?
    price    Float
    imageUrl String
    // Out-of-stock ingredients can't be added as extras.
    available Boolean @default(true)

    products     Product[]
    cartItems    CartItem[]
    shoppingItem ShoppingItem?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

// Shared shopping list for staff. Auto-filled when an ingredient goes
// out-of-stock (ingredientId set), plus free-text items added by hand.
model ShoppingItem {
    id    Int    @id @default(autoincrement())
    label String

    ingredient   Ingredient? @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
    ingredientId Int?        @unique

    createdAt DateTime @default(now())
}

model Cart {
    id Int @id @default(autoincrement())

    user   User? @relation(fields: [userId], references: [id], onDelete: Cascade)
    userId Int?  @unique

    items CartItem[]

    token String

    totalAmount Float @default(0)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model CartItem {
    id Int @id @default(autoincrement())

    cart   Cart @relation(fields: [cartId], references: [id], onDelete: Cascade)
    cartId Int

    productItem   ProductItem @relation(fields: [productItemId], references: [id])
    productItemId Int

    quantity Int @default(1)

    ingredients Ingredient[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Order {
    id Int @id @default(autoincrement())

    user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)
    userId Int?

    token String

    totalAmount Float
    status      OrderStatus
    paymentId   String?

    items Json

    fullName String
    email    String
    phone    String
    address  String
    comment  String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model VerificationCode {
    id Int @id @default(autoincrement())

    user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
    userId Int  @unique

    code String

    createdAt DateTime @default(now())

    @@unique([userId, code])
}

model Story {
    id              Int    @id @default(autoincrement())
    previewImageUrl String

    items StoryItem[]

    createdAt DateTime @default(now())
}

model StoryItem {
    id Int @id @default(autoincrement())

    storyId Int
    story   Story @relation(fields: [storyId], references: [id])

    sourceUrl String

    createdAt DateTime @default(now())
}

enum OrderStatus {
    PENDING // created, awaiting payment
    SUCCEEDED // paid / confirmed
    PREPARING // kitchen started
    READY // ready for delivery
    OUT_FOR_DELIVERY // courier en route
    DELIVERED // completed
    CANCELLED
}

enum UserRole {
    USER
    ADMIN
    KITCHEN
}
